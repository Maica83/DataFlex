38958>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38958>>>                Case Break
38959>>>
38959>>>            Case Else // must be nfUndefined
38959>>>
38959>>>        Case End
38959>>>
38959>>>        Send SetActionButtons
